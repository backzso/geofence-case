// Geofence Service — Prisma Schema
// Schema: geofence (isolated from other services)
// DATABASE_URL must include ?schema=geofence so Prisma targets the correct schema.

generator client {
  provider = "prisma-client-js"
  output   = "../src/infrastructure/persistence/generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// The `geom` column is a PostGIS geometry type which Prisma does not natively support.
// It is declared as Unsupported so Prisma can track the column in its schema but will
// NOT generate typed accessors for it. All geometry reads/writes happen via raw SQL
// exclusively in PrismaAreaRepository. Never access geom through the Prisma client object.
model Area {
  id         String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String                        @db.VarChar(120)
  geom       Unsupported("geometry(Polygon,4326)")
  createdAt  DateTime                      @default(dbgenerated("NOW()")) @map("created_at") @db.Timestamptz()

  @@map("areas")
}
