// Location Service — Prisma Schema
// Schema: location (isolated from other services)
// DATABASE_URL must include ?schema=location so Prisma targets the correct schema.

generator client {
  provider = "prisma-client-js"
  output   = "../src/infrastructure/persistence/generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserAreaState {
  userId    String   @map("user_id") @db.Uuid
  areaId    String   @map("area_id") @db.Uuid
  updatedAt DateTime @default(dbgenerated("NOW()")) @map("updated_at") @db.Timestamptz()

  @@id([userId, areaId])
  @@map("user_area_state")
}

// Outbox events — inserted atomically with user_area_state mutations.
// Claimed by OutboxPollerService and published to Kafka asynchronously.
model OutboxEvent {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId       String    @unique @map("event_id") @db.Uuid
  aggregateType String    @map("aggregate_type") @db.VarChar(64)
  aggregateId   String?   @map("aggregate_id") @db.Uuid
  eventType     String    @map("event_type") @db.VarChar(64)
  partitionKey  String    @map("partition_key") @db.VarChar(128)
  payload       Json      @map("payload")
  status        String    @default("pending") @db.VarChar(16)
  attempts      Int       @default(0)
  availableAt   DateTime  @default(dbgenerated("NOW()")) @map("available_at") @db.Timestamptz()
  publishedAt   DateTime? @map("published_at") @db.Timestamptz()
  createdAt     DateTime  @default(dbgenerated("NOW()")) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @default(dbgenerated("NOW()")) @map("updated_at") @db.Timestamptz()

  @@map("outbox_events")
}

// User-level watermark to prevent stale event processing even when user_area_state is empty.
model UserProcessingWatermark {
  userId          String   @id @map("user_id") @db.Uuid
  lastProcessedAt DateTime @map("last_processed_at") @db.Timestamptz()
  updatedAt       DateTime @default(dbgenerated("NOW()")) @map("updated_at") @db.Timestamptz()

  @@map("user_processing_watermarks")
}
